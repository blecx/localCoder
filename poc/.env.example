# localCoder PoC — environment variables
# Copy this file to .env and fill in as needed.

# ── LLM Gateway ─────────────────────────────────────────────────────────────
# Leave blank to run in stub (dummy) mode — no real API calls, always works.
OPENAI_API_KEY=

# Override to use an OpenAI-compatible alternative (e.g. Azure, LiteLLM proxy).
# OPENAI_BASE_URL=https://api.openai.com

# Model to use when in OpenAI mode.
# LLM_MODEL=gpt-4o-mini

# ── GitHub Copilot (alternative provider) ────────────────────────────────────
# GitHub OAuth token with an active Copilot subscription.
# COPILOT_TOKEN=ghu_your_token_here

# ── Generic OpenAI-compatible (Ollama, vLLM, LM Studio, …) ──────────────────
# LLM_API_KEY=ollama
# LLM_API_BASE=http://localhost:11434/v1

# ── Hub (PostgreSQL) ─────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://hub:hub@db:5432/hub
# ARTIFACTS_DIR=/data/artifacts
# REPOS_DIR=/data/repos

# ── Hub (SQLite, standalone mode) ────────────────────────────────────────────
# LOCALCODER_DB=/path/to/localcoder.db   # default: poc/.localcoder.db

# ── Python runner ────────────────────────────────────────────────────────────
# PYTHON_RUNNER_TIMEOUT=10   # seconds

# ── CLI (used locally, not inside Docker) ───────────────────────────────────
# HUB_URL=http://localhost:8000
# LLM_GATEWAY_URL=http://localhost:8001
