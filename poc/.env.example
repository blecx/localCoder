# localCoder PoC – environment variable template
# Copy this file to .env and fill in at least one provider credential.

# ── GitHub Copilot ────────────────────────────────────────────────────────────
# GitHub OAuth token with an active Copilot subscription.
# COPILOT_TOKEN=ghu_your_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1   # optional override

# ── Generic OpenAI-compatible (Ollama, vLLM, LM Studio, …) ───────────────────
# LLM_API_KEY=ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=llama3

# ── Database ──────────────────────────────────────────────────────────────────
# LOCALCODER_DB=/path/to/localcoder.db   # default: poc/.localcoder.db

# ── Python runner ─────────────────────────────────────────────────────────────
# PYTHON_RUNNER_TIMEOUT=10   # seconds
